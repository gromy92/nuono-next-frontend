# Frontend address.
E2E_BASE_URL=http://127.0.0.1:9620

# Backend address.
E2E_API_BASE_URL=http://127.0.0.1:18080

# Real admin login is optional in local snapshot data.
E2E_ADMIN_USERNAME=<TEST_ADMIN_USERNAME>
E2E_ADMIN_PASSWORD=<TEST_ADMIN_PASSWORD>

# Reserved for future non-admin permission tests.
E2E_USER_USERNAME=<TEST_USER_USERNAME>
E2E_USER_PASSWORD=<TEST_USER_PASSWORD>

# Local-only admin bypass. Use this for the old snapshot because it has no real role_id=1 admin account.
E2E_USE_DEV_SESSION=true

# Safe write tests create and delete temporary roles/menus only.
E2E_ALLOW_WRITE_TESTS=false

# Keep disabled unless a dedicated disposable database and cleanup script are available.
E2E_ALLOW_DIRTY_WRITE_TESTS=false

E2E_DATA_PREFIX=E2E_
E2E_EXPECTED_LANDING_PATH=
E2E_WORKERS=1
